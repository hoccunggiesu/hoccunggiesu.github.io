---
import Layout from '../../layouts/Layout.astro';
import { getAllEntities } from '../../utils/content.ts';
import { marked } from 'marked';

export async function getStaticPaths() {
  const entities = getAllEntities();

  return entities.map(entity => ({
    params: { slug: entity.path },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const htmlContent = marked.parse(entity.fullContent || '');
---

<Layout title={`${entity.fullName} - Chi tiết dòng tu`}>
	<div class="max-w-4xl mx-auto">
		<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
			<a href="/search" class="text-blue-600 hover:text-blue-800 flex items-center gap-2 transition-colors w-fit">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Quay lại danh sách
			</a>
			<span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded border border-blue-200 w-fit">
				{entity.category}
			</span>
		</div>

		<article class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 md:p-12 prose prose-blue prose-slate max-w-none prose-headings:text-blue-900 prose-a:text-blue-600 hover:prose-a:text-blue-800">
			<div set:html={htmlContent} />
		</article>
	</div>
</Layout>
